<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>Configuration settings for AccessGraph AI integration</description>
    <enableFeeds>false</enableFeeds>
    <label>AccessGraph Settings</label>
    <visibility>Public</visibility>

    <fields>
        <fullName>API_Endpoint__c</fullName>
        <description>Base URL for AccessGraph AI API</description>
        <externalId>false</externalId>
        <label>API Endpoint</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>

    <fields>
        <fullName>Organization_ID__c</fullName>
        <description>AccessGraph AI Organization ID (auto-populated on installation)</description>
        <externalId>false</externalId>
        <label>Organization ID</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>

    <fields>
        <fullName>Auto_Sync_Enabled__c</fullName>
        <defaultValue>true</defaultValue>
        <description>Enable automatic daily sync of permissions to AccessGraph AI</description>
        <externalId>false</externalId>
        <label>Auto Sync Enabled</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>

    <fields>
        <fullName>Last_Sync_Date__c</fullName>
        <description>Timestamp of last successful sync</description>
        <externalId>false</externalId>
        <label>Last Sync Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>DateTime</type>
    </fields>

    <fields>
        <fullName>Sync_Status__c</fullName>
        <description>Status of the last sync operation</description>
        <externalId>false</externalId>
        <label>Sync Status</label>
        <length>50</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
</CustomObject>

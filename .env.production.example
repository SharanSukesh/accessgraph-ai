# ==============================================
# AccessGraph AI - Production Environment
# ==============================================
# This is a template for production deployment
# NEVER commit actual credentials to git!

# -----------------------------
# Database - PostgreSQL
# -----------------------------
# Railway/Render auto-provide DATABASE_URL
DATABASE_URL=${{Postgres.DATABASE_URL}}

# OR manually set:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------
# Graph Database - Neo4j Aura
# -----------------------------
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_strong_password_here

# -----------------------------
# Cache - Redis
# -----------------------------
# Railway/Render auto-provide REDIS_URL
REDIS_URL=${{Redis.REDIS_URL}}

# OR manually set:
# REDIS_URL=redis://user:password@host:6379/0

# -----------------------------
# Backend API
# -----------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=$PORT  # Railway/Render use $PORT variable
BACKEND_RELOAD=false  # IMPORTANT: Set to false in production!
BACKEND_LOG_LEVEL=info
BACKEND_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# -----------------------------
# Frontend
# -----------------------------
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_APP_NAME=AccessGraph AI
NODE_ENV=production

# -----------------------------
# Salesforce OAuth
# -----------------------------
SALESFORCE_CLIENT_ID=your_salesforce_consumer_key
SALESFORCE_CLIENT_SECRET=your_salesforce_consumer_secret
SALESFORCE_REDIRECT_URI=https://api.your-domain.com/auth/salesforce/callback
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# For Salesforce Sandbox:
# SALESFORCE_LOGIN_URL=https://test.salesforce.com

# -----------------------------
# Application Mode
# -----------------------------
DEMO_MODE=false

# -----------------------------
# Security (Optional but Recommended)
# -----------------------------
# SECRET_KEY=generate_a_random_secret_key_here
# JWT_SECRET=generate_another_random_secret_here
# ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# -----------------------------
# Monitoring (Optional)
# -----------------------------
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# LOG_LEVEL=info

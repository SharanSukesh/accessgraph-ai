# ==============================================
# AccessGraph AI - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# -----------------------------
# Database - PostgreSQL
# -----------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=accessgraph
POSTGRES_USER=accessgraph
POSTGRES_PASSWORD=change_me_in_production

# Full connection string (auto-constructed in services)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------
# Graph Database - Neo4j
# -----------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_production

# -----------------------------
# Cache - Redis
# -----------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------
# Backend API
# -----------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_LOG_LEVEL=info
BACKEND_CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# External URL for API (from frontend perspective)
BACKEND_URL=http://localhost:8000

# -----------------------------
# Frontend
# -----------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AccessGraph AI

# -----------------------------
# Development
# -----------------------------
NODE_ENV=development
PYTHONUNBUFFERED=1

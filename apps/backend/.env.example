# ==============================================
# AccessGraph AI - Backend Environment Variables
# ==============================================

# Application
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false
BACKEND_LOG_LEVEL=info

# CORS - IMPORTANT: Add your frontend URL here
# Comma-separated list of allowed origins
# Production: Add your Railway frontend URL
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.accessgraphai.com

# Database - PostgreSQL (production) or SQLite (dev/demo)
# For Railway: Use DATABASE_URL from Railway PostgreSQL service
# For SQLite demo: sqlite+aiosqlite:///./accessgraph.db
DATABASE_URL=sqlite+aiosqlite:///./accessgraph.db

# Database - Neo4j (optional, for graph visualization)
# For Neo4j Aura: Get connection details from console
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_production

# Cache - Redis (optional)
# For Railway: Use REDIS_URL from Railway Redis service
REDIS_URL=redis://localhost:6379/0

# Demo Mode
# Set to true to use mock data (no Salesforce required)
# Set to false when using real Salesforce connection
DEMO_MODE=true

# Salesforce OAuth (required when DEMO_MODE=false)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=https://api.accessgraphai.com/auth/salesforce/callback
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Frontend URL (where OAuth redirects users back after login)
# Production: https://app.accessgraphai.com
# Local dev:  http://localhost:3000
FRONTEND_URL=https://app.accessgraphai.com

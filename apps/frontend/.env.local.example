# AccessGraph AI Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Backend API URL
# Default: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# App Configuration
NEXT_PUBLIC_APP_NAME=AccessGraph AI

# Demo Mode
# When true, app will work with sample/demo data even if backend is unavailable
NEXT_PUBLIC_DEMO_MODE=false

# Enable TanStack Query Devtools
# Set to 'true' during development to see React Query devtools
NEXT_PUBLIC_ENABLE_QUERY_DEVTOOLS=true

# Graph Visualization Settings
# Max nodes to render before showing warning
NEXT_PUBLIC_GRAPH_MAX_NODES=500

# Default organization ID (for development)
# Leave empty in production
NEXT_PUBLIC_DEFAULT_ORG_ID=

# Feature Flags
NEXT_PUBLIC_ENABLE_GRAPH_EXPORT=true
NEXT_PUBLIC_ENABLE_CSV_EXPORT=true
NEXT_PUBLIC_ENABLE_ANOMALY_DETECTION=true

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=
